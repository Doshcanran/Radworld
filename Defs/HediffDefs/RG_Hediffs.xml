<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>RG_RadiationSickness</defName>
    <label>лучевая болезнь</label>
    <description>Организм повреждён накопленным радиационным облучением.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <initialSeverity>0.01</initialSeverity>
    <stages>
      <li>
        <minSeverity>0.00</minSeverity>
        <label>лучевая болезнь (лёгкая)</label>
        <painFactor>0.10</painFactor>
        <partEfficiencyOffset>-0.05</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.35</minSeverity>
        <label>лучевая болезнь (средняя)</label>
        <painFactor>0.25</painFactor>
        <partEfficiencyOffset>-0.15</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.70</minSeverity>
        <label>лучевая болезнь (терминальная)</label>
        <painFactor>0.60</painFactor>
        <partEfficiencyOffset>-0.35</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.35</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.40</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.25</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
