<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>RG_RadiationAccumulation</defName>
    <label>накопленная радиация</label>
    <description>Скрытый внутренний счетчик полученной радиации.</description>
    <hediffClass>Verse.HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <everCurableByItem>false</everCurableByItem>
    <scenarioCanAdd>false</scenarioCanAdd>
    <initialSeverity>0</initialSeverity>
    <stages>
      <li>
        <minSeverity>0</minSeverity>
        <label>накопленная радиация</label>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAtTargetValue>false</disappearsAtTargetValue>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>RG_RadiationSickness</defName>
    <label>лучевая болезнь</label>
    <description>Организм страдает от накопленной радиации. На поздней стадии болезнь смертельна.</description>
    <hediffClass>Verse.HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <everCurableByItem>false</everCurableByItem>
    <initialSeverity>0.01</initialSeverity>
    <stages>
      <li>
        <minSeverity>0.00</minSeverity>
        <label>лучевая болезнь (лёгкая)</label>
        <painFactor>0.10</painFactor>
        <vomitingMtbDays>8</vomitingMtbDays>
        <partEfficiencyOffset>-0.05</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.35</minSeverity>
        <label>лучевая болезнь (средняя)</label>
        <painFactor>0.25</painFactor>
        <vomitingMtbDays>3</vomitingMtbDays>
        <partEfficiencyOffset>-0.15</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.70</minSeverity>
        <label>лучевая болезнь (терминальная)</label>
        <painFactor>0.60</painFactor>
        <vomitingMtbDays>1</vomitingMtbDays>
        <partEfficiencyOffset>-0.35</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.35</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.40</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.25</offset>
          </li>
        </capMods>
      </li>
    </stages>
    <comps>
      <li Class="RG_RadiationFramework.HediffCompProperties_KillOnSeverity">
        <killAtSeverity>1.0</killAtSeverity>
        <deathMessageKey>RG_RadiationDeathMessage</deathMessageKey>
      </li>
    </comps>
  </HediffDef>
</Defs>
